{
  "kind": "collectionType",
  "collectionName": "team_members",
  "info": {
    "singularName": "team-member",
    "pluralName": "team-members",
    "displayName": "Team Member",
    "description": "Yoga instructors and team members"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "content-manager": {
      "visible": true
    },
    "content-type-builder": {
      "visible": true
    }
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "title": {
      "type": "string",
      "required": true
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "bio": {
      "type": "customField",
      "customField": "plugin::tinymce.tinymce",
      "required": false
    },
    "active": {
      "type": "boolean",
      "default": true
    },
    "sortOrder": {
      "type": "integer"
    },
    "socialLink": {
      "type": "component",
      "repeatable": false,
      "component": "social.social-link",
      "required": false
    }
  }
}

{
  "kind": "collectionType",
  "collectionName": "retreats",
  "info": {
    "singularName": "retreat",
    "pluralName": "retreats",
    "displayName": "Retreat",
    "description": "Yoga retreats and wellness events"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "content-manager": {
      "visible": true
    },
    "content-type-builder": {
      "visible": true
    }
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "subtitle": {
      "type": "string",
      "required": false
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "location": {
      "type": "string",
      "required": true
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "body": {
      "type": "richtext",
      "required": true
    },
    "active": {
      "type": "boolean",
      "default": true
    },
    "sortOrder": {
      "type": "integer"
    },
    "startDate": {
      "type": "date",
      "required": false
    },
    "endDate": {
      "type": "date",
      "required": false
    }
  }
}

{
  "kind": "singleType",
  "collectionName": "team_page",
  "info": {
    "singularName": "team-page",
    "pluralName": "team-pages",
    "displayName": "Team Page",
    "description": "Manage the order of team members displayed on the team page"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "content-manager": {
      "visible": true
    },
    "content-type-builder": {
      "visible": true
    }
  },
  "attributes": {
    "team_members": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::team-member.team-member",
      "mappedBy": "team_page",
      "pluginOptions": {
        "content-manager": {
          "edit": {
            "page": {
              "size": 50
            }
          }
        }
      }
    }
  }
}
